<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AccountRegistrationApp.ViewModels"
        x:Class="AccountRegistrationApp.Views.RegistrationWindow"
        x:DataType="vm:RegistrationViewModel"
        Title="Регистрация"
        Width="450"
        Height="600"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:RegistrationViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">

        <!-- Шапка -->
        <Border Grid.Row="0"
                Background="{DynamicResource SukiBackground}"
                Padding="20,15">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Регистрация"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource SukiText}" />
                <TextBlock Text="Создайте новый аккаунт"
                           FontSize="13"
                           Foreground="{DynamicResource SukiSubText}" />
            </StackPanel>
        </Border>

        <!-- Форма регистрации -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="30,20" Spacing="15">

                <!-- Логин -->
                <TextBlock Text="Логин"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SukiText}" />
                <TextBox Watermark="Введите логин (мин. 3 символа)"
                         Text=""
                         Classes="SukiTextBox" />

                <!-- Email -->
                <TextBlock Text="Email"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SukiText}"
                           Margin="0,10,0,0" />
                <TextBox Watermark="example@mail.com"
                         Text=""
                         Classes="SukiTextBox" />

                <!-- Пароль -->
                <TextBlock Text="Пароль"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SukiText}"
                           Margin="0,10,0,0" />
                <TextBox Watermark="Минимум 4 символа"
                         Text=""
                         PasswordChar="•"
                         Classes="SukiTextBox" />

                <!-- Подтверждение пароля -->
                <TextBlock Text="Подтверждение пароля"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SukiText}"
                           Margin="0,10,0,0" />
                <TextBox Watermark="Повторите пароль"
                         Text=""
                         PasswordChar="•"
                         Classes="SukiTextBox" />

                <!-- Кнопка регистрации -->
                <Button 
                        Classes="SukiButton"
                        Background="{DynamicResource SukiPrimary}"
                        Foreground="White"
                        Content=""
                        HorizontalAlignment="Stretch"
                        Height="45"
                        Margin="0,20,0,0"
                        FontWeight="Bold" />

                <!-- Кнопка возврата -->
                <Button 
                        Classes="SukiButton"
                        Background="Transparent"
                        Foreground="{DynamicResource SukiPrimary}"
                        Content="◀ Войти"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>